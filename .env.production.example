# ========================================================================
# Beehus - Backend production environment example
# Copy to: ./.env (production host)
# ========================================================================

MONGO_USER=admin
MONGO_PASS=CHANGE_ME
MONGO_URI=mongodb://admin:CHANGE_ME@mongo:27017
MONGO_DB_NAME=platform_db

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

REDIS_URL=redis://redis:6379/0
# Host path mounted into containers at /downloads (docker-compose volume source).
HOST_DOWNLOADS_DIR=./downloads
# In-container download path used by app/worker code (Chrome download dir).
DOWNLOADS_DIR=/downloads

SELENIUM_REMOTE_URL=http://selenium-hub:4444/wd/hub
VNC_URL_BASE=https://beehus.placestecnologia.com.br
VNC_HOST_PORT_BASE=7901
SELENIUM_MAX_SLOTS=5
SELENIUM_NODE_COUNT=2
SELENIUM_NODE_MAX_SESSIONS=1

JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
TOKEN_ENC_KEY=CHANGE_ME_FERNET_KEY

ADMIN_EMAIL=admin@beehus.placestecnologia.com.br
ADMIN_PASSWORD=CHANGE_ME
ADMIN_FULL_NAME=Admin User

FRONTEND_URL=https://beehus.placestecnologia.com.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Beehus Platform
SMTP_USE_TLS=true
